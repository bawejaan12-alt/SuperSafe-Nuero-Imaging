# Copy this file to .env.local for local development.
# In Vercel, set these under Project Settings → Environment Variables instead —
# never commit a real .env file.

# Set to "false" once your FastAPI backend is deployed and reachable.
# Any other value (or leaving it unset) keeps the app in demo/mock mode.
REACT_APP_MOCK_MODE=true

# Where your FastAPI backend lives. Update once it's deployed
# (e.g. Render, Railway, Fly.io, or a Vercel serverless function).
REACT_APP_API_BASE_URL=http://localhost:8000
